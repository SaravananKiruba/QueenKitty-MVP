# QueenKitty API environment.
# Copy to .env and fill in values. Never commit the real .env.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=queenkitty
DB_USER=root
DB_PASS=

# Use a long random string in production. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Token lifetime in seconds (default 30 days)
JWT_TTL=2592000

# Comma-separated list of allowed CORS origins for the SPA in dev.
# Production same-origin deployments can leave this empty.
CORS_ORIGINS=http://localhost:5173

APP_ENV=local
